<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    tools:context=".fragment.HomeFragment">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/color_f5f7fb">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/_100sdp"
            android:background="@drawable/ic_bg_app_sign_in"
            android:orientation="horizontal">

        </LinearLayout>
        <LinearLayout
            android:id="@+id/llUserNameWallet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="@dimen/_10sdp"
            android:orientation="horizontal">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/ivUserProfile"
                android:layout_width="@dimen/_40sdp"
                android:layout_height="@dimen/_40sdp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_app_logo" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_10sdp"
                android:layout_weight="1"
                android:orientation="vertical">

                <androidx.appcompat.widget.AppCompatTextView
                    style="@style/TextView_bold"
                    android:text=""
                    android:id="@+id/tvNameHome"
                    android:textColor="@color/white"
                    android:textSize="@dimen/_16ssp" />

                <androidx.appcompat.widget.AppCompatTextView
                    style="@style/TextView_regular"
                    android:text=""
                    android:id="@+id/tvMobileHome"
                    android:textColor="@color/white"
                    android:textSize="@dimen/_10ssp" />
            </LinearLayout>

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvWalletBalance"
                style="@style/TextView_regular"
                android:text=""
                android:textSize="@dimen/_12ssp"
                android:textColor="@color/white" />

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivRefreshAmount"
                android:layout_width="@dimen/_20sdp"
                android:layout_height="@dimen/_20sdp"
                android:layout_marginStart="@dimen/_5sdp"
                android:src="@drawable/ic_refresh" />
        </LinearLayout>
        <androidx.cardview.widget.CardView
            android:layout_below="@+id/llUserNameWallet"
            android:layout_marginVertical="@dimen/_5sdp"
            android:layout_marginHorizontal="@dimen/_15sdp"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_120sdp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="@dimen/_10sdp">
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <com.asksira.loopingviewpager.LoopingViewPager
                    android:id="@+id/loopingViewPager"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipToPadding="false"
                    app:autoScroll="true"
                    app:isInfinite="true"
                    app:scrollInterval="5000"
                    app:viewpagerAspectRatio="1.78" />

                <me.relex.circleindicator.CircleIndicator
                    android:id="@+id/pageIndicatorView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentBottom="true"
                    android:layout_centerHorizontal="true"
                    android:layout_marginBottom="20dp"
                    app:ci_drawable="@drawable/bg_select_circle"
                    app:ci_drawable_unselected="@drawable/bg_unselect_circle" />
            </RelativeLayout>
        </androidx.cardview.widget.CardView>
    </RelativeLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_gravity="center"
        android:gravity="center"
        android:paddingBottom="@dimen/_10sdp"
        android:background="@color/color_f5f7fb">
        <LinearLayout
            android:id="@+id/llAddMoney"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_gravity="center"
            android:gravity="center"
            android:layout_margin="@dimen/_5sdp"
            android:orientation="vertical">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/_10sdp"
                android:layout_gravity="center"
                android:gravity="center"
                android:background="@drawable/bg_background"
                android:padding="@dimen/_10sdp">
                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="@dimen/_15sdp"
                    android:layout_height="@dimen/_15sdp"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:src="@drawable/ic_add_money"/>
            </LinearLayout>
            <androidx.appcompat.widget.AppCompatTextView
                style="@style/TextView_regular"
                android:text="@string/add_money"
                android:layout_gravity="center"
                android:gravity="center"
                android:textColor="@color/black"
                android:textSize="@dimen/_10ssp"/>
        </LinearLayout>
        <LinearLayout
            android:id="@+id/llMyEarnings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/_5sdp"
            android:layout_weight="1"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/_10sdp"
                android:background="@drawable/bg_background"
                android:layout_gravity="center"
                android:gravity="center"
                android:padding="@dimen/_10sdp">
                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="@dimen/_15sdp"
                    android:layout_height="@dimen/_15sdp"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:src="@drawable/ic_transfer"/>
            </LinearLayout>
            <androidx.appcompat.widget.AppCompatTextView
                style="@style/TextView_regular"
                android:text="@string/my_earnings"
                android:layout_gravity="center"
                android:gravity="center"
                android:textColor="@color/black"
                android:textSize="@dimen/_10ssp"/>
        </LinearLayout>
        <LinearLayout
            android:id="@+id/llRechargeHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/_5sdp"
            android:layout_weight="1"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/_10sdp"
                android:background="@drawable/bg_background"
                android:layout_gravity="center"
                android:gravity="center"
                android:padding="@dimen/_10sdp">
                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="@dimen/_15sdp"
                    android:layout_height="@dimen/_15sdp"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:src="@drawable/ic_recharge_history"/>
            </LinearLayout>
            <androidx.appcompat.widget.AppCompatTextView
                style="@style/TextView_regular"
                android:text="@string/recharge_history"
                android:layout_gravity="center"
                android:gravity="center"
                android:textColor="@color/black"
                android:textSize="@dimen/_10ssp"/>
        </LinearLayout>
        <LinearLayout
            android:id="@+id/llMargins"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_gravity="center"
            android:gravity="center"
            android:layout_margin="@dimen/_5sdp"
            android:orientation="vertical">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/_10sdp"
                android:layout_gravity="center"
                android:gravity="center"
                android:background="@drawable/bg_background"
                android:padding="@dimen/_10sdp">
                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="@dimen/_15sdp"
                    android:layout_height="@dimen/_15sdp"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:src="@drawable/ic_margins"/>
            </LinearLayout>
            <androidx.appcompat.widget.AppCompatTextView
                style="@style/TextView_regular"
                android:text="@string/margin"
                android:layout_gravity="center"
                android:gravity="center"
                android:textColor="@color/black"
                android:textSize="@dimen/_10ssp"/>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginHorizontal="@dimen/_10sdp"
        android:layout_marginVertical="@dimen/_15sdp"
        android:padding="@dimen/_5sdp"
        android:background="@drawable/bg_gradiant_color">
        <androidx.appcompat.widget.AppCompatTextView
            style="@style/TextView_medium"
            android:layout_weight="1"
            android:padding="@dimen/_10sdp"
            android:text="@string/wallet_balance"
            android:textColor="@color/white"/>
        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvCheckBalance"
            style="@style/TextView_bold"
            android:text="@string/_0000"
            android:padding="@dimen/_10sdp"
            android:textColor="@color/white"/>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/rvHome"/>

</LinearLayout>