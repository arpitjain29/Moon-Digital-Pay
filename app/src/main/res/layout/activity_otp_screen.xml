<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".OtpScreenActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/_170sdp"
        android:orientation="vertical"
        android:background="@drawable/ic_bg_app_sign_in"
        android:padding="@dimen/_10sdp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivBackClick"
                android:layout_width="@dimen/_35sdp"
                android:layout_height="@dimen/_35sdp"
                android:padding="@dimen/_5sdp"
                android:src="@drawable/ic_arrow_left"/>
            <androidx.appcompat.widget.AppCompatTextView
                style="@style/TextView_bold"
                android:text="OTP Verification"
                android:textColor="@color/white"
                android:layout_marginTop="@dimen/_15sdp"
                android:textSize="@dimen/_30sdp"/>
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <androidx.appcompat.widget.AppCompatTextView
                style="@style/TextView_medium"
                android:layout_weight="1"
                android:text="Otp your mobile number"
                android:layout_gravity="center"
                android:textColor="@color/white"
                android:textSize="@dimen/_12ssp"/>
            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="@dimen/_70sdp"
                android:layout_height="@dimen/_40sdp"
                android:layout_gravity="center"
                android:src="@drawable/ic_app_logo"/>
        </LinearLayout>

    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="@dimen/_10sdp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <androidx.appcompat.widget.AppCompatEditText
                android:id="@+id/etOtp1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:maxLength="1"
                android:inputType="number"
                android:textSize="@dimen/_14ssp"
                android:layout_margin="@dimen/_10sdp"
                android:padding="@dimen/_10sdp"
                android:textColor="@color/Color1A1C1E"
                android:fontFamily="@font/plusjakartasans_regular"
                app:fontFamily="@font/plusjakartasans_regular"
                android:layout_gravity="center"
                android:gravity="center"/>
            <androidx.appcompat.widget.AppCompatEditText
                android:id="@+id/etOtp2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:maxLength="1"
                android:inputType="number"
                android:textSize="@dimen/_14ssp"
                android:layout_margin="@dimen/_10sdp"
                android:padding="@dimen/_10sdp"
                android:textColor="@color/Color1A1C1E"
                android:fontFamily="@font/plusjakartasans_regular"
                app:fontFamily="@font/plusjakartasans_regular"
                android:layout_gravity="center"
                android:gravity="center"/>
            <androidx.appcompat.widget.AppCompatEditText
                android:id="@+id/etOtp3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:maxLength="1"
                android:inputType="number"
                android:textSize="@dimen/_14ssp"
                android:layout_margin="@dimen/_10sdp"
                android:padding="@dimen/_10sdp"
                android:textColor="@color/Color1A1C1E"
                android:fontFamily="@font/plusjakartasans_regular"
                app:fontFamily="@font/plusjakartasans_regular"
                android:layout_gravity="center"
                android:gravity="center"/>
            <androidx.appcompat.widget.AppCompatEditText
                android:id="@+id/etOtp4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:maxLength="1"
                android:inputType="number"
                android:textSize="@dimen/_14ssp"
                android:layout_margin="@dimen/_10sdp"
                android:padding="@dimen/_10sdp"
                android:textColor="@color/Color1A1C1E"
                android:fontFamily="@font/plusjakartasans_regular"
                app:fontFamily="@font/plusjakartasans_regular"
                android:layout_gravity="center"
                android:gravity="center"/>
        </LinearLayout>
<!--        <com.google.android.material.textfield.TextInputLayout-->
<!--            style="@style/TextInputLayoutAppearance"-->
<!--            android:layout_marginTop="@dimen/_10sdp"-->
<!--            android:hint="@string/otp">-->
<!--            <com.google.android.material.textfield.TextInputEditText-->
<!--                android:id="@+id/etOtp"-->
<!--                style="@style/Edittext"-->
<!--                android:maxLength="10"-->
<!--                android:inputType="text"-->
<!--                android:hint="@string/enter_otp"/>-->
<!--        </com.google.android.material.textfield.TextInputLayout>-->



        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDone"
            style="@style/MaterialButton"
            android:text="@string/verify_otp"
            android:layout_marginTop="@dimen/_10sdp"/>
        <LinearLayout
            android:padding="@dimen/_10sdp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="horizontal">
            <androidx.appcompat.widget.AppCompatTextView
                style="@style/TextView_bold"
                android:text="Don't received the OTP?"
                android:textColor="@color/Color1A1C1E"
                android:padding="@dimen/_3sdp"
                android:layout_gravity="end"
                android:textSize="@dimen/_12ssp"/>
            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvResendOtp"
                style="@style/TextView_bold"
                android:text="Resend Otp"
                android:padding="@dimen/_3sdp"
                android:textColor="@color/color_red"
                android:gravity="center"
                android:layout_gravity="center"
                android:textSize="@dimen/_12ssp"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>