<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.MoonDigitalPay" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/color_blue</item>
        <item name="colorPrimaryVariant">@color/color_blue</item>
        <item name="colorOnPrimary">@color/color_blue</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/color_blue</item>
        <item name="colorSecondaryVariant">@color/color_blue</item>
        <item name="colorOnSecondary">@color/color_blue</item>
        <item name="android:statusBarColor">@color/color_blue</item>
        <item name="android:windowLightStatusBar" tools:ignore="NewApi">false</item>
        <item name="android:windowBackground">@color/white</item>
        <!-- Customize your theme here. -->
        <item name="android:windowActionBar">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>


    <style name="TextInputLayoutAppearance" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="boxStrokeColor">@color/edit_box_color</item>
        <item name="boxStrokeWidth">@dimen/_1sdp</item>
        <item name="fontFamily">@font/plusjakartasans_regular</item>
        <item name="android:fontFamily">@font/plusjakartasans_regular</item>
        <item name="boxBackgroundColor">@color/white</item>
        <item name="hintTextColor">@color/ColorB8BABD</item>
        <item name="backgroundColor">@color/white</item>
        <item name="expandedHintEnabled">false</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/_8sdp</item>
        <item name="boxCornerRadiusBottomStart">@dimen/_8sdp</item>
        <item name="boxCornerRadiusTopEnd">@dimen/_8sdp</item>
        <item name="boxCornerRadiusTopStart">@dimen/_8sdp</item>
        <item name="colorPrimary">@color/color_blue</item>
    </style>


    <style name="Edittext" parent="Widget.Design.TextInputLayout">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/Color1A1C1E</item>
        <item name="android:textColorHint">@color/ColorB8BABD</item>
        <item name="android:background">@null</item>
        <item name="android:drawablePadding">@dimen/_12sdp</item>
        <item name="android:textSize">@dimen/_14ssp</item>
        <item name="android:padding">@dimen/_15sdp</item>
        <item name="fontFamily">@font/plusjakartasans_semibold</item>
        <item name="android:fontFamily">@font/plusjakartasans_semibold</item>
        <item name="colorPrimary">@color/color_blue</item>
    </style>

    <style name="TextView_regular" parent="Widget.AppCompat.TextView">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">@dimen/_14ssp</item>
        <item name="fontFamily">@font/plusjakartasans_regular</item>
        <item name="android:fontFamily">@font/plusjakartasans_regular</item>
    </style>

    <style name="TextView_medium" parent="Widget.AppCompat.TextView">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">@dimen/_14ssp</item>
        <item name="fontFamily">@font/plusjakartasans_medium</item>
        <item name="android:fontFamily">@font/plusjakartasans_medium</item>
    </style>

    <style name="TextView_bold" parent="Widget.AppCompat.TextView">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">@dimen/_14ssp</item>
        <item name="fontFamily">@font/plusjakartasans_bold</item>
        <item name="android:fontFamily">@font/plusjakartasans_bold</item>
    </style>

    <style name="TextView_semi_bold" parent="Widget.AppCompat.TextView">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">@dimen/_14ssp</item>
        <item name="fontFamily">@font/plusjakartasans_semibold</item>
        <item name="android:fontFamily">@font/plusjakartasans_semibold</item>
    </style>


    <style name="MaterialButton" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:padding">@dimen/_8sdp</item>
        <item name="fontFamily">@font/plusjakartasans_semibold</item>
        <item name="backgroundTint">@color/color_red</item>
        <item name="android:fontFamily">@font/plusjakartasans_semibold</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">@dimen/_10sdp</item>
        <item name="android:textSize">@dimen/_16ssp</item>
    </style>

    <style name="CustomAlertDialogStyle_space" parent="android:Theme.Holo.Light.Dialog">
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:background">@android:color/transparent</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <!--        <item name="android:windowAnimationStyle">@style/DialogAnimation</item>-->
        <item name="android:layout_marginStart">@dimen/_10sdp</item>
        <item name="android:layout_marginEnd">@dimen/_10sdp</item>
        <item name="android:layout_marginTop">@dimen/_10sdp</item>
        <item name="android:layout_marginBottom">@dimen/_10sdp</item>
    </style>

    <style name="CustomAlertDialogStylePopup" parent="android:Theme.Holo.Light.Dialog">
        <item name="android:background">@android:color/transparent</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowAnimationStyle">@style/DialogAnimation</item>
    </style>

    <style name="DialogAnimation">
        <item name="android:windowEnterAnimation">@anim/slide_up_dialog</item>
        <item name="android:windowExitAnimation">@anim/slide_out_down</item>
    </style>

    <style name="NavigationDrawerStyle">
        <item name="android:textSize">@dimen/_12ssp</item><!-- text size in menu-->
        <item name="fontFamily">@font/plusjakartasans_regular</item>
        <item name="android:fontFamily">@font/plusjakartasans_regular</item>
        <item name="android:textColor">@color/Color1A1C1E</item>
    </style>

</resources>